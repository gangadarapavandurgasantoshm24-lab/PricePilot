{
  "name": "pricepilot-backend",
  "version": "1.0.0",
  "description": "Express REST API backend for PricePilot price comparison.",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "node server.js",
    "test": "jest --testPathPatterns=tests/ --forceExit",
    "test:watch": "jest --testPathPatterns=tests/ --watch",
    "test:coverage": "jest --testPathPatterns=tests/ --coverage --forceExit"
  },
  "jest": {
    "testEnvironment": "node",
    "testTimeout": 15000
