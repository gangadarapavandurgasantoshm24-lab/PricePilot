  "author": "Gangadara Pavan Durga Santosh",
  "license": "ISC",
  "dependencies": {
    "axios": "^1.18.1",
    "cors": "^2.8.5",
    "express": "^4.19.2",
    "playwright": "^1.61.1"
  },
  "devDependencies": {
    "jest": "^30.4.2",
    "supertest": "^7.2.2"
  }
}
