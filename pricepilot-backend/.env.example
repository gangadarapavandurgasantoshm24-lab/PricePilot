# PricePilot Backend – Environment Template
# Copy this file to .env and fill in your values
# cp .env.example .env

# ─── Server ────────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ─── Redis Cache (optional – server runs without Redis, caching is disabled) ───
REDIS_URL=redis://localhost:6379
CACHE_TTL=300

# ─── Amazon Product Advertising API v5 (optional) ──────────────────────────────
# Get credentials from: https://affiliate-program.amazon.in/
# If not set, the Amazon provider falls back to mock data automatically.
AMAZON_ACCESS_KEY=your_amazon_access_key_here
AMAZON_SECRET_KEY=your_amazon_secret_key_here
AMAZON_PARTNER_TAG=your_partner_tag-21
AMAZON_REGION=us-east-1
AMAZON_MARKETPLACE=www.amazon.in

# ─── Provider settings ─────────────────────────────────────────────────────────
DEFAULT_TIMEOUT=5000
RETRY_COUNT=2
RETRY_DELAY=1000

# ─── Playwright Browser Pool ───────────────────────────────────────────────────
BROWSER_HEADLESS=true
BROWSER_SLOW_MO=0
BROWSER_TIMEOUT=30000
BROWSER_MAX_CONCURRENT=2
BROWSER_MAX_PAGES=5
BROWSER_QUEUE_TIMEOUT=60000

# ─── Pagination defaults ───────────────────────────────────────────────────────
DEFAULT_PAGE=1
DEFAULT_LIMIT=20
MAX_LIMIT=100
